---
import { translations } from '../i18n/translations';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Eduardo De la Cruz — DevOps Engineer & Tech Lead',
  description =
    'Software Engineer, DevOps & Tech Lead con 10 años de experiencia. Especializado en AWS, CI/CD, Python, TypeScript, Terraform y arquitectura cloud. Lima, Perú.',
} = Astro.props;
---

<!doctype html>
<html lang="es" data-lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Eduardo De la Cruz Rojas" />
    <meta name="keywords" content="DevOps, Software Engineer, Tech Lead, AWS, CI/CD, Terraform, Python, TypeScript, Docker, heyedu.dev" />
    <meta name="theme-color" content="#0f0f1a" />
    <!-- Open Graph / LinkedIn / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://heyedu.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://heyedu.dev" />
  </head>
  <body class="bg-[#0f0f1a] text-slate-100 antialiased">
    <slot />

    <!-- i18n + scroll reveal + lang toggle -->
    <script define:vars={{ t: translations }}>
      const LANG_KEY = 'preferred-lang';

      function getLang() {
        return localStorage.getItem(LANG_KEY) || 'es';
      }

      function getNestedValue(obj, path) {
        return path.split('.').reduce((acc, key) => acc?.[key], obj);
      }

      function applyTranslations(lang) {
        const dict = t[lang];
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          const value = getNestedValue(dict, key);
          if (value !== undefined && typeof value === 'string') {
            el.textContent = value;
          }
        });
        document.dispatchEvent(
          new CustomEvent('langchange', { detail: { lang, t: dict } })
        );
      }

      function updateLangButtons(lang) {
        document.querySelectorAll('.lang-toggle-btn').forEach((btn) => {
          btn.textContent = t[lang].nav.langToggle;
        });
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('lang', lang);
        document.title = t[lang].meta.title;
        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc) metaDesc.setAttribute('content', t[lang].meta.description);
      }

      function setLang(lang) {
        localStorage.setItem(LANG_KEY, lang);
        updateLangButtons(lang);
        applyTranslations(lang);
      }

      document.addEventListener('DOMContentLoaded', () => {
        // Init language
        setLang(getLang());

        // Lang toggle buttons
        document.querySelectorAll('.lang-toggle-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            setLang(getLang() === 'es' ? 'en' : 'es');
          });
        });

        // Intersection Observer for reveal animations
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -48px 0px' }
        );

        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
